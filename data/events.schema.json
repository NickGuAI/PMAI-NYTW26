{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PMAI New York Tech Week 2026 Event",
  "type": "object",
  "required": [
    "id",
    "title",
    "event_url",
    "event_url_kind",
    "date",
    "start_time",
    "timezone",
    "host",
    "location",
    "tracks",
    "description",
    "description_source",
    "keywords",
    "source_event_url",
    "source_checked_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable local event ID."
    },
    "title": {
      "type": "string"
    },
    "event_url": {
      "type": "string",
      "format": "uri"
    },
    "event_url_kind": {
      "type": "string",
      "enum": ["external", "tech_week_calendar_fallback"]
    },
    "external_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "source_event_url": {
      "type": "string",
      "format": "uri"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "start_time": {
      "type": "string"
    },
    "end_time": {
      "type": ["string", "null"]
    },
    "timezone": {
      "type": "string"
    },
    "host": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "location_source": {
      "type": "string",
      "enum": ["tech_week", "external_page", "unavailable"]
    },
    "tracks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "description": {
      "type": "string"
    },
    "description_source": {
      "type": "string",
      "enum": ["direct_fetch", "tavily_fallback", "unavailable"]
    },
    "description_source_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "description_fetch_error": {
      "type": ["string", "null"]
    },
    "description_fallback_attempted": {
      "type": "boolean"
    },
    "description_fallback_source": {
      "type": ["string", "null"]
    },
    "description_fallback_error": {
      "type": ["string", "null"]
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inferred_categories": {
      "type": "array",
      "description": "High-confidence derived category hints from source tracks plus title, host, and location signals. Not source-backed track membership.",
      "items": {
        "type": "string",
        "enum": [
          "AI + Infra",
          "Hackathons",
          "Fintech",
          "Students",
          "Engineers",
          "Founders",
          "GTM",
          "Investors"
        ]
      }
    },
    "source_checked_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
